<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>fitcss — tokens</title>
<link rel="stylesheet" href="css/fit.css">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #fff;
    color: #18181b;
    padding: 2.5rem;
    line-height: 1.5;
    background-image: url("data:image/png;base64,")
  }
  h1  {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 2rem;
  }
  h1 em {
    font-style: normal;
    font-weight: 400;
    color: #a1a1aa;
    }
  h2  {
    font-size: 3em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -2px;
    color: #71717a;
    margin-bottom: 1.25rem;
    margin-top: 3rem;
  }
  h3  { font-size: .8125rem; font-weight: 500; color: #52525b; margin-bottom: .5rem; margin-top: 1.75rem; text-transform: capitalize; }
  .ratio-label { font-family: 'SFMono-Regular', Menlo, monospace; font-size: .7rem; font-weight: 400; color: #a1a1aa; text-transform: none; }
  code { font-family: 'SFMono-Regular', Menlo, monospace; font-size: .7rem; color: #71717a; display: block; }
  .hint { font-size: .7rem; color: #a1a1aa; margin-top: -.75rem; margin-bottom: 1rem; }

  /* Color matrix */
  .color-matrix       { display: flex; flex-direction: column; gap: 0; }
  .color-matrix-row   { display: flex; align-items: center }
  .color-row-label    { width: 52px; flex-shrink: 0; font-size: .6875rem; font-weight: 600; color: #71717a; font-family: 'SFMono-Regular', Menlo, monospace; }
  .color-hue-header   { width: 100px; flex-shrink: 0; font-size: .6875rem; font-weight: 600; color: #52525b; text-transform: capitalize; text-align: center; margin-bottom: .25rem; }
  .swatch             { width: 100px; height: 40px; flex-shrink: 0; }
  .swatch-empty       { width: 100px; height: 40px; border: 1px solid #d4d4d8; background: transparent; flex-shrink: 0; }

  .type-row { display: flex; align-items: baseline; gap: 1.5rem; padding: .5rem 0; border-bottom: 1px solid #f4f4f5; }
  .type-row:last-child { border-bottom: none; }

  .spacing-columns { display: flex; gap: 2rem; align-items: flex-start; }
  .spacing-col { flex: 1; min-width: 0; }
  .spacing-col h3 { margin-top: 0; }
  .spacing-row { display: flex; align-items: center; gap: .75rem; padding: .375rem 0; border-bottom: 1px solid #f4f4f5; }
  .spacing-row:last-child { border-bottom: none; }
  .spacing-vis { flex: 1; min-width: 0; }
  .spacing-box { width: 32px; background: #6366f1; opacity: .2; border-radius: 2px; min-height: 2px; }

  .label { width: 80px; flex-shrink: 0; }

  .shadow-columns { display: flex; gap: 2rem; align-items: flex-start; }
  .shadow-col { flex: 1; min-width: 0; }
  .shadow-col h3 { margin-top: 0; }
  .shadow-row { display: flex; align-items: center; gap: .75rem; padding: .5rem 0; border-bottom: 1px solid #f4f4f5; }
  .shadow-row:last-child { border-bottom: none; }
  .shadow-card { width: 36px; height: 36px; background: #fff; border-radius: 4px; margin: 6px; flex-shrink: 0; }

  /* Base step highlight */
  .color-matrix-row.is-base .color-row-label { color: #4f46e5; font-weight: 700; }
  .type-row.is-base code,
  .spacing-row.is-base code,
  .shadow-row.is-base code { color: #4f46e5; }
</style>
</head>
<body>
  <h1>fitcss <em>/ design tokens</em></h1>

  <section>
    <h2>Colors</h2>
    <div class="color-matrix">
      <div class="color-matrix-row">
        <div class="color-row-label"></div>
        {{#colorHues}}<div class="color-hue-header">{{name}}</div>{{/colorHues}}
      </div>
      {{#colorRows}}
      <div class="color-matrix-row{{#isBase}} is-base{{/isBase}}">
        <div class="color-row-label">{{label}}</div>
        {{#cells}}{{#filled}}<div class="swatch" style="background:{{hex}}" title=".{{colorClass}}"></div>{{/filled}}{{^filled}}<div class="swatch-empty"></div>{{/filled}}{{/cells}}
      </div>
      {{/colorRows}}
    </div>
  </section>

  <section>
    <h2>Type Scale</h2>
    {{#typeGroups}}
    <h3>{{bpLabel}} <span class="ratio-label">{{ratio}}</span></h3>
    {{#steps}}
    <div class="type-row{{#isBase}} is-base{{/isBase}}">
      <code class="label">.{{cls}}</code>
      <span class="{{cls}}">The quick brown fox jumps</span>
    </div>
    {{/steps}}
    {{/typeGroups}}
  </section>

  <section>
    <h2>Spacing</h2>
    <p class="hint">height = spacing value at each step</p>
    <div class="spacing-columns">
    {{#spacingGroups}}
    <div class="spacing-col">
      <h3>{{bpLabel}} <span class="ratio-label">{{ratio}}</span></h3>
      {{#steps}}
      <div class="spacing-row{{#isBase}} is-base{{/isBase}}">
        <code class="label">.{{cls}}</code>
        <div class="spacing-vis">
          <div class="spacing-box" style="height:{{heightRem}}rem"></div>
        </div>
      </div>
      {{/steps}}
    </div>
    {{/spacingGroups}}
    </div>
  </section>

  <section>
    <h2>Box Shadow</h2>
    <div class="shadow-columns">
    {{#shadowGroups}}
    <div class="shadow-col">
      <h3>{{bpLabel}} <span class="ratio-label">{{ratio}}</span></h3>
      {{#steps}}
      <div class="shadow-row{{#isBase}} is-base{{/isBase}}">
        <code class="label">.{{cls}}</code>
        <div class="shadow-card {{cls}}"></div>
      </div>
      {{/steps}}
    </div>
    {{/shadowGroups}}
    </div>
  </section>
</body>
</html>
